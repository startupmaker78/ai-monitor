# === База данных ===
# Yandex Cloud Managed PostgreSQL (regions: ru-central1)
DATABASE_URL=postgresql://user:password@host.mdb.yandexcloud.net:6432/dbname?sslmode=verify-full
# Локальный shadow Postgres для prisma migrate diff (Docker на 5433)
SHADOW_DATABASE_URL=postgresql://shadow:shadow@localhost:5433/shadow

# === NextAuth ===
# Сгенерировать: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# === Yandex Object Storage (S3-совместимый) ===
YOS_BUCKET_NAME=
YOS_ENDPOINT=https://storage.yandexcloud.net
YOS_REGION=ru-central1
YOS_ACCESS_KEY_ID=
YOS_SECRET_ACCESS_KEY=
YOS_PUBLIC_URL=

# === Anthropic Claude API (для AI-анализа) ===
ANTHROPIC_API_KEY=

# === Яндекс.Метрика OAuth (после MVP) ===
METRIKA_CLIENT_ID=
METRIKA_CLIENT_SECRET=

# === ЮКасса (платежи) ===
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# === Resend (email) ===
RESEND_API_KEY=

# === Безопасность ===
# Соль для хэширования IP в trekinge (см. PRODUCT.md "152-ФЗ")
IP_HASH_SALT=
