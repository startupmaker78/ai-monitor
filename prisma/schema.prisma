generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CONTRACTOR
  OWNER
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contractorProfile    ContractorProfile?
  ownerProfile         OwnerProfile?
  applications         PartnerApplication[] @relation("ApplicantApplications")
  reviewedApplications PartnerApplication[] @relation("ReviewedApplications")
}

model ContractorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  totalEarned Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients OwnerProfile[]
}

// TODO(2026-04-27): дублирование с Site — siteUrl/tildaSiteId/metrikaCounterId/metrikaToken
// пересекаются с тем, что должно жить в Site. Разрулить на этапе 0.c.5
// (см. DECISIONS.md «2026-04-27: Открытый вопрос — дублирование metrika-полей
// между OwnerProfile и Site»).
model OwnerProfile {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  contractorId     String?
  contractor       ContractorProfile? @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  siteUrl          String?
  tildaSiteId      String?
  metrikaCounterId String?
  metrikaToken     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  sites Site[]
}

model Site {
  id            String   @id @default(cuid())
  ownerId       String
  owner         OwnerProfile @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  domain        String
  trackingToken String       @unique
  isDemo        Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  sessions Session[]

  @@index([ownerId])
}

model Session {
  id           String    @id @default(cuid())
  siteId       String
  site         Site      @relation(fields: [siteId], references: [id], onDelete: Restrict)
  sessionToken String    @unique
  ipHash       String    @db.Char(64)
  userAgent    String    @db.Text
  startedAt    DateTime
  endedAt      DateTime?
  eventsCount  Int       @default(0)
  storageKey   String?

  @@index([siteId, startedAt])
  @@index([startedAt])
}

model PartnerApplication {
  id              String                   @id @default(cuid())
  userId          String
  user            User                     @relation("ApplicantApplications", fields: [userId], references: [id], onDelete: Restrict)
  companyName     String
  experience      String                   @db.Text
  portfolioUrl    String?
  telegram        String?
  phone           String?
  status          PartnerApplicationStatus @default(PENDING)
  rejectionReason String?                  @db.Text
  reviewedById    String?
  reviewedBy      User?                    @relation("ReviewedApplications", fields: [reviewedById], references: [id], onDelete: Restrict)
  reviewedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}
