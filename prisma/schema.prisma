generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CONTRACTOR
  OWNER
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionTier {
  BASIC
  STANDARD
  PROFESSIONAL
  CORPORATE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum SubscriptionEventType {
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND
  UPGRADE
  DOWNGRADE
  CANCELED
  EXPIRED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contractorProfile    ContractorProfile?
  ownerProfile         OwnerProfile?
  applications         PartnerApplication[] @relation("ApplicantApplications")
  reviewedApplications PartnerApplication[] @relation("ReviewedApplications")
}

model ContractorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  totalEarned Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients OwnerProfile[]
}

model OwnerProfile {
  id           String             @id @default(cuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  contractorId String?
  contractor   ContractorProfile? @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  sites              Site[]
  subscription       Subscription?
  subscriptionEvents SubscriptionEvent[]
}

model Site {
  id               String       @id @default(cuid())
  ownerId          String
  owner            OwnerProfile @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  domain           String
  trackingToken    String       @unique
  isDemo           Boolean      @default(false)
  metrikaCounterId String?
  metrikaToken     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  sessions Session[]

  @@index([ownerId])
}

model Session {
  id               String    @id @default(cuid())
  siteId           String
  site             Site      @relation(fields: [siteId], references: [id], onDelete: Restrict)
  sessionToken     String    @unique
  ipHash           String    @db.Char(64)
  userAgent        String    @db.Text
  startedAt        DateTime
  endedAt          DateTime?
  eventsCount      Int       @default(0)
  storageKey       String?
  analysisTargetId String?

  @@index([siteId, startedAt])
  @@index([startedAt])
  @@index([analysisTargetId])
}

model PartnerApplication {
  id              String                   @id @default(cuid())
  userId          String
  user            User                     @relation("ApplicantApplications", fields: [userId], references: [id], onDelete: Restrict)
  companyName     String
  experience      String                   @db.Text
  portfolioUrl    String?
  telegram        String?
  phone           String?
  status          PartnerApplicationStatus @default(PENDING)
  rejectionReason String?                  @db.Text
  reviewedById    String?
  reviewedBy      User?                    @relation("ReviewedApplications", fields: [reviewedById], references: [id], onDelete: Restrict)
  reviewedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model Subscription {
  id                      String             @id @default(cuid())
  ownerId                 String             @unique
  owner                   OwnerProfile       @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  tier                    SubscriptionTier
  status                  SubscriptionStatus
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  analysesUsedThisPeriod  Int                @default(0)
  analysesLimit           Int
  sessionsLimit           Int
  sessionsAllocated       Int                @default(0)
  cancelAtPeriodEnd       Boolean            @default(false)
  yookassaCustomerId      String?
  yookassaPaymentMethodId String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  events SubscriptionEvent[]

  @@index([currentPeriodEnd])
  @@index([status])
}

model SubscriptionEvent {
  id                String                @id @default(cuid())
  ownerId           String
  owner             OwnerProfile          @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  subscriptionId    String?
  subscription      Subscription?         @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  type              SubscriptionEventType
  tierBefore        SubscriptionTier?
  tierAfter         SubscriptionTier?
  amount            Decimal?              @db.Decimal(10, 2)
  currency          String?               @db.Char(3)
  yookassaPaymentId String?               @unique
  yookassaPayload   Json?
  occurredAt        DateTime
  createdAt         DateTime              @default(now())

  @@index([ownerId, occurredAt])
  @@index([subscriptionId, occurredAt])
}
