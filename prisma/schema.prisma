generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  CONTRACTOR
  OWNER
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionTier {
  BASIC
  STANDARD
  PROFESSIONAL
  CORPORATE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum SubscriptionEventType {
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  REFUND
  UPGRADE
  DOWNGRADE
  CANCELED
  EXPIRED
}

enum AnalysisTargetStatus {
  ACTIVE
  READY
  ANALYZING
  COMPLETED
  ARCHIVED
}

enum MetricsSource {
  METRIKA
  MANUAL
}

enum AnalysisStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum RecommendationPriority {
  CRITICAL
  IMPORTANT
  GOOD
}

enum RecommendationStatus {
  NEW
  IN_PROGRESS
  DONE
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(OWNER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contractorProfile    ContractorProfile?
  ownerProfile         OwnerProfile?
  applications         PartnerApplication[] @relation("ApplicantApplications")
  reviewedApplications PartnerApplication[] @relation("ReviewedApplications")
  analysesRequested    Analysis[]           @relation("AnalysesRequested")
}

model ContractorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  totalEarned Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clients      OwnerProfile[]
  inviteTokens InviteToken[]
}

model OwnerProfile {
  id           String             @id @default(cuid())
  userId       String             @unique
  user         User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  contractorId String?
  contractor   ContractorProfile? @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  sites              Site[]
  subscription       Subscription?
  subscriptionEvents SubscriptionEvent[]
}

model Site {
  id               String       @id @default(cuid())
  ownerId          String
  owner            OwnerProfile @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  domain           String
  trackingToken    String       @unique
  isDemo           Boolean      @default(false)
  metrikaCounterId String?
  metrikaToken     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  sessions         Session[]
  analysisTargets  AnalysisTarget[]
  metricsSnapshots MetricsSnapshot[]
  analyses         Analysis[]

  @@index([ownerId])
}

model Session {
  id               String          @id @default(cuid())
  siteId           String
  site             Site            @relation(fields: [siteId], references: [id], onDelete: Restrict)
  sessionToken     String          @unique
  ipHash           String          @db.Char(64)
  userAgent        String          @db.Text
  startedAt        DateTime
  endedAt          DateTime?
  eventsCount      Int             @default(0)
  storageKey       String?
  analysisTargetId String?
  analysisTarget   AnalysisTarget? @relation(fields: [analysisTargetId], references: [id], onDelete: SetNull)

  @@index([siteId, startedAt])
  @@index([startedAt])
  @@index([analysisTargetId])
}

model AnalysisTarget {
  id                String               @id @default(cuid())
  siteId            String
  site              Site                 @relation(fields: [siteId], references: [id], onDelete: Restrict)
  url               String
  name              String?
  sessionsBudget    Int
  sessionsCollected Int                  @default(0)
  status            AnalysisTargetStatus @default(ACTIVE)
  archivedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  sessions Session[]
  analyses Analysis[]

  @@index([siteId, status])
  @@index([archivedAt])
}

model MetricsSnapshot {
  id                 String        @id @default(cuid())
  siteId             String
  site               Site          @relation(fields: [siteId], references: [id], onDelete: Restrict)
  date               DateTime      @db.Date
  visits             Int
  uniqueVisitors     Int
  conversions        Int
  bounceRate         Decimal       @db.Decimal(5, 2)
  avgSessionDuration Int
  goals              Json?
  source             MetricsSource @default(METRIKA)
  createdAt          DateTime      @default(now())

  @@unique([siteId, date])
}

model Analysis {
  id                   String         @id @default(cuid())
  siteId               String
  site                 Site           @relation(fields: [siteId], references: [id], onDelete: Restrict)
  targetId             String
  target               AnalysisTarget @relation(fields: [targetId], references: [id], onDelete: Restrict)
  requestedById        String
  requestedBy          User           @relation("AnalysesRequested", fields: [requestedById], references: [id], onDelete: Restrict)
  status               AnalysisStatus @default(PENDING)
  prompt               String?        @db.Text
  sessionsAnalyzed     Int            @default(0)
  tokensUsed           Int            @default(0)
  recommendationsCount Int            @default(0)
  createdAt            DateTime       @default(now())
  completedAt          DateTime?

  recommendations Recommendation[]

  @@index([siteId, createdAt])
  @@index([targetId, createdAt])
}

model Recommendation {
  id              String                 @id @default(cuid())
  analysisId      String
  analysis        Analysis               @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  priority        RecommendationPriority
  title           String
  description     String                 @db.Text
  metric          String?
  status          RecommendationStatus   @default(NEW)
  sortOrder       Int
  rejectionReason String?                @db.Text
  acceptedAt      DateTime?
  appliedAt       DateTime?
  metricsBefore   Json?
  metricsAfter    Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([analysisId, sortOrder])
  @@index([status])
}

model PartnerApplication {
  id              String                   @id @default(cuid())
  userId          String
  user            User                     @relation("ApplicantApplications", fields: [userId], references: [id], onDelete: Restrict)
  companyName     String
  experience      String                   @db.Text
  portfolioUrl    String?
  telegram        String?
  phone           String?
  status          PartnerApplicationStatus @default(PENDING)
  rejectionReason String?                  @db.Text
  reviewedById    String?
  reviewedBy      User?                    @relation("ReviewedApplications", fields: [reviewedById], references: [id], onDelete: Restrict)
  reviewedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model InviteToken {
  id           String            @id @default(cuid())
  contractorId String
  contractor   ContractorProfile @relation(fields: [contractorId], references: [id], onDelete: Restrict)
  email        String
  token        String            @unique
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime          @default(now())

  @@index([contractorId])
  @@index([email])
  @@index([expiresAt])
}

model Subscription {
  id                      String             @id @default(cuid())
  ownerId                 String             @unique
  owner                   OwnerProfile       @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  tier                    SubscriptionTier
  status                  SubscriptionStatus
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  analysesUsedThisPeriod  Int                @default(0)
  analysesLimit           Int
  sessionsLimit           Int
  sessionsAllocated       Int                @default(0)
  cancelAtPeriodEnd       Boolean            @default(false)
  yookassaCustomerId      String?
  yookassaPaymentMethodId String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  events SubscriptionEvent[]

  @@index([currentPeriodEnd])
  @@index([status])
}

model SubscriptionEvent {
  id                String                @id @default(cuid())
  ownerId           String
  owner             OwnerProfile          @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  subscriptionId    String?
  subscription      Subscription?         @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)
  type              SubscriptionEventType
  tierBefore        SubscriptionTier?
  tierAfter         SubscriptionTier?
  amount            Decimal?              @db.Decimal(10, 2)
  currency          String?               @db.Char(3)
  yookassaPaymentId String?               @unique
  yookassaPayload   Json?
  occurredAt        DateTime
  createdAt         DateTime              @default(now())

  @@index([ownerId, occurredAt])
  @@index([subscriptionId, occurredAt])
}
